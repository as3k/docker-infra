# ─── Site Domain ───────────────────────────────────────────────────────────────
# Used for Traefik routing and TLS cert generation.
# Backbone app stacks (e.g., docker-msdev) must use the same domain.
SITE_DOMAIN=msdev.com

# ─── Database ──────────────────────────────────────────────────────────────────
# App stacks in backbone mode connect to infra-mariadb with these creds.
DB_NAME=msdev
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_ROOT_PASSWORD=rootpassword

# ─── Redis ────────────────────────────────────────────────────────────────────
# App stacks in backbone mode connect to infra-redis with this password.
REDIS_PASSWORD=redispassword
