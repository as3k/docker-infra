# ─── Site Domain ───────────────────────────────────────────────────────────────
# Used for Traefik routing and TLS cert generation.
# App stacks in backbone mode must use the same domain.
SITE_DOMAIN=dev.local

# ─── Databases ────────────────────────────────────────────────────────────────
# MariaDB
# App stacks in backbone mode connect to infra-mariadb with these creds.
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=apppassword
DB_ROOT_PASSWORD=rootpassword

# PostgreSQL
# Internal hostname: infra-postgres. Exposed on host port 5433.
PG_NAME=appdb
PG_USER=appuser
PG_PASSWORD=apppassword

# ─── Redis ────────────────────────────────────────────────────────────────────
# App stacks in backbone mode connect to infra-redis with this password.
REDIS_PASSWORD=redispassword
